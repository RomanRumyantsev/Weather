@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Weather App — Clean Architecture</title>
    <link href="@Url.Content("~/Content/bootstrap.min.css")" rel="stylesheet" />

    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', sans-serif;
        }

        .weather-card {
            background: rgba(255, 255, 255, 0.95);
            border-radius: 24px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            width: 100%;
            max-width: 480px;
            overflow: hidden;
        }

        .hourly-scroll {
            display: flex;
            overflow-x: auto; 
            overflow-y: hidden;
            gap: 12px;
            padding: 10px 5px;
            scrollbar-width: thin;
            scrollbar-color: #764ba2 #f8f9fa;
        }

            .hourly-scroll::-webkit-scrollbar {
                height: 6px;
            }

            .hourly-scroll::-webkit-scrollbar-thumb {
                background: #764ba2;
                border-radius: 10px;
            }

        .hourly-item {
            flex: 0 0 auto;
            min-width: 85px;
            background: #f8f9fa;
            border-radius: 15px;
            padding: 12px 8px;
            text-align: center;
            box-shadow: 0 2px 5px rgba(0,0,0,0.05);
        }

        .d-none {
            display: none !important;
        }

        .border-bottom-dashed {
            border-bottom: 1px dashed #dee2e6;
        }
    </style>
</head>
<body>

    <div class="weather-card shadow-lg">

        <div id="loader" class="p-5 text-center">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-3 text-muted fw-bold">Загрузка данных...</p>
        </div>

        <div id="error-block" class="p-5 text-center d-none">
            <h4 class="text-danger fw-bold">Ошибка сервиса</h4>
            <p id="error-text" class="text-muted small"></p>
            <button class="btn btn-primary rounded-pill px-4" onclick="weatherApp.init()">Повторить</button>
        </div>

        <div id="weather-content" class="d-none">
            <div class="p-4 text-center border-bottom bg-light">
                <h3 class="fw-bold mb-0">Москва</h3>
                <p id="current-date" class="text-muted small text-uppercase"></p>
                <div class="d-flex justify-content-center align-items-center my-2">
                    <img id="curr-icon" src="" style="width: 80px;">
                    <div class="display-2 fw-bold ms-2" id="curr-temp">--</div>
                    <div class="h3 align-self-start mt-3">°C</div>
                </div>
                <h5 id="curr-condition" class="text-secondary fw-normal">--</h5>
            </div>

            <div class="p-4 border-bottom">
                <h6 class="text-muted fw-bold small text-uppercase mb-2">Ближайшие часы</h6>
                <div class="hourly-scroll" id="hourly-list"></div>
            </div>

            <div class="p-4">
                <h6 class="text-muted fw-bold small text-uppercase mb-2">Прогноз на 3 дня</h6>
                <div id="daily-list"></div>
            </div>
        </div>
    </div>

    <script src="@Url.Content("~/Scripts/jquery-3.7.0.min.js")"></script>

    <script>
    const weatherApp = {
        ui: {
            loader: '#loader',
            error: '#error-block',
            content: '#weather-content',
            errorText: '#error-text'
        },

        init: function() {
            this.toggleState('loading');
            this.fetch();
        },

        toggleState: function(state, msg = '') {
            $(this.ui.loader).addClass('d-none');
            $(this.ui.error).addClass('d-none');
            $(this.ui.content).addClass('d-none');

            if (state === 'loading') $(this.ui.loader).removeClass('d-none');
            if (state === 'success') $(this.ui.content).removeClass('d-none');
            if (state === 'error') {
                $(this.ui.errorText).text(msg);
                $(this.ui.error).removeClass('d-none');
            }
        },

        fetch: function() {
            const self = this;
            $.ajax({
                url: '@Url.Action("GetWeatherData", "Home")',
                type: 'GET',
                cache: false,
                success: function(data) {
                    if (data.error) {
                        self.toggleState('error', data.error);
                    } else {
                        self.render(data);
                        self.toggleState('success');
                    }
                },
                error: function(xhr) {
                    self.toggleState('error', 'Ошибка соединения: ' + xhr.status);
                }
            });
        },

        render: function(data) {
            $('#curr-temp').text(Math.round(data.Current.TempC));
            $('#curr-condition').text(data.Current.Condition.Text);
            $('#curr-icon').attr('src', 'https:' + data.Current.Condition.Icon);
            $('#current-date').text(new Date().toLocaleDateString('ru-RU', { weekday: 'long', day: 'numeric', month: 'long' }));

            const hHtml = data.Hourly.map(h => `
                <div class="hourly-item shadow-sm">
                    <small class="text-muted d-block">${h.Time.split(' ')[1]}</small>
                    <img src="https:${h.Condition.Icon}" width="35">
                    <div class="fw-bold">${Math.round(h.TempC)}°</div>
                </div>
            `).join('');
            $('#hourly-list').html(hHtml);

            const dHtml = data.Daily.map(d => `
                <div class="d-flex justify-content-between align-items-center py-2 border-bottom-dashed">
                    <span class="fw-bold" style="width: 90px;">${new Date(d.Date).toLocaleDateString('ru-RU', { weekday: 'short', day: 'numeric' })}</span>
                    <div class="d-flex align-items-center flex-grow-1">
                        <img src="https:${d.Condition.Icon}" width="32">
                        <span class="small text-muted ms-2">${d.Condition.Text}</span>
                    </div>
                    <span class="fw-bold text-end" style="width: 80px;">${Math.round(d.MaxTempC)}° / ${Math.round(d.MinTempC)}°</span>
                </div>
            `).join('');
            $('#daily-list').html(dHtml);
        }
    };

    $(function() {
        weatherApp.init();
    });
    </script>

</body>
</html>

